# Host-environment secrets for paid access. Copy to .env.local for local dev.
# NONE of these are exposed to the browser — they are read only by the API
# routes (and the mint CLI). Never commit real values.

# Required. The HMAC secret that signs/verifies access codes and session tokens.
# Use a long random string (e.g. `openssl rand -base64 48`). The SAME secret must
# be used by the mint CLI and the running site.
ACCESS_SIGNING_SECRET=

# Optional. Active payment rail: "telegram" (default, offline HMAC) or "crypto".
# Falls back to config.paymentProvider when unset.
PAYMENT_PROVIDER=telegram

# Only for the "crypto" rail — a hosted processor's API base + key. The site asks
# the processor for an order's status; it never watches chains directly.
CRYPTO_API_URL=
CRYPTO_API_KEY=

# ---------------------------------------------------------------------------
# User accounts (Supabase). Create a free project at https://supabase.com,
# then copy Project Settings → API into these. When the two NEXT_PUBLIC_* vars
# are absent the account features stay dark and the anonymous builder works as
# before (see lib/supabase/env.ts → isSupabaseConfigured).
# ---------------------------------------------------------------------------

# Public — safe to expose to the browser. The anon key is gated by Row-Level
# Security, so it can only ever read/write rows the signed-in user owns.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Required only for privileged, validated maintenance writes such as
# account-bound entitlement redemption. Never prefix this with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only salt for usage metrics ("Uses" tracking, migration 0009). /api/track
# hashes (session id + coarse IP) with this to produce the anonymous actor_hash /
# ip_hash — raw values never reach the DB. Use a long random string (e.g.
# `openssl rand -base64 48`). When unset, usage events are silently dropped (the
# rest of the app is unaffected). Must be set in the deploy env to record metrics.
METRICS_SALT=

# ---------------------------------------------------------------------------
# Pro Boosters content (the paywalled enhancement blocks). Kept OUT of the repo
# so the public source never ships the paid text. Value is base64 of a JSON
# object: { "global": Booster[], "byTemplate": { "<templateId>": Booster[] } }
# (Booster = { id, label, note?, text }). Encode with:
#   node -e "process.stdout.write(Buffer.from(JSON.stringify(require('./boosters.json'))).toString('base64'))"
# When unset, a small generic sample is served (see data/premium/boosters.ts).
# ---------------------------------------------------------------------------
PRO_BOOSTERS_B64=
